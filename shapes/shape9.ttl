@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix ex:   <http://www.example.org/#> .

ex:DeprecatedIRIUsageShape
  a sh:NodeShape ;
  sh:targetNode sh:this ;
  sh:sparql [
    a sh:SPARQLConstraint ;
    sh:message "Deprecated term used: {?iri} (owl:deprecated true). Context triple: {?s ?p ?o}" ;
    sh:select """
      SELECT ?this ?iri ?s ?p ?o WHERE {
        ?s ?p ?o .

        {
          BIND(?p AS ?iri)
          FILTER(isIRI(?iri))
          ?iri <http://www.w3.org/2002/07/owl#deprecated> true .
        }
        UNION
        {
          BIND(?o AS ?iri)
          FILTER(isIRI(?iri))
          ?iri <http://www.w3.org/2002/07/owl#deprecated> true .
        }

        BIND(?s AS ?this)
      }
    """ ;
  ] .